# Environment Variables for AmbulAI
# Copy this file to .env and fill in the actual values

# Database & Cache (Defaults for docker-compose)
DATABASE_URL=postgresql://postgres:postgres@db:5432/ambulai
REDIS_URL=redis://redis:6379/0

# API Keys
# Gemini API Key: Get this from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyAhCnoomQh9U0UAI9_bhgXL0u95N23zxuA

# Google Maps API Key: Get this from Google Cloud Console (needs Routes and Geocoding APIs enabled)
MAPS_API_KEY=your_google_maps_api_key_here

# Twilio (Optional for MVP, needed for SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# Security
JWT_SECRET=v9jSHyID3Ji6MEeo2QwVCJAvNmfGILXlUxosnpZVqsY
